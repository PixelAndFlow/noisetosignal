# Server
PORT=3001
NODE_ENV=development
CLIENT_URL=http://localhost:5173

# Demo mode (local SQLite — no Neon or Google required)
DEV_MODE=true
DATABASE_URL=sqlite:./data/dev.db

# Production: set DEV_MODE=false and use Neon PostgreSQL
# DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# Google OAuth (optional for local demo; required for production)
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-client-secret
GOOGLE_REDIRECT_URI=http://localhost:3001/api/auth/google/callback

# Session cookie (auto-generated by npm run setup)
SESSION_SECRET=change-me-to-a-long-random-string
