# Copy this file to .env and fill in your values

# Neon PostgreSQL — from neon.tech dashboard
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# Google OAuth — from Google Cloud Console > APIs & Services > Credentials
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-client-secret

# YouTube Data API v3 — from Google Cloud Console > APIs & Services > Credentials
YOUTUBE_API_KEY=your-api-key

# AES-256-GCM key for token encryption — generate with:
# node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=64-char-hex-string

# JWT signing secret — generate with:
# node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=128-char-hex-string

# Your deployed URL (used for OAuth callback) — localhost for dev
CLIENT_URL=http://localhost:5173

# Port (optional, defaults to 3001)
PORT=3001
